<Window x:Class="TMP_Laba3.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TMP_Laba3"
        mc:Ignorable="d"
        Title="Вход"
        FontSize="20"
        Background="LightBlue"
        Height="320"
        Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel>
            <TextBlock Text="АИС Отдел кадров"
                       Background="LightYellow"
                       TextAlignment="Right"
                       Padding="0, 0, 5, 0"/>
            
            <TextBlock x:Name="VersionTextBlock"
                       Text="Версия 1.0.0.0"
                       Background="Yellow"
                       TextAlignment="Right"
                       Padding="0, 0, 5, 0"/>
            
            <TextBlock Text="Введите имя пользователя и пароль"
                       Background="White"
                       TextAlignment="Right"
                       Padding="0, 0, 5, 0"/>

            <Border Height="25"/>

            <DockPanel>
                <TextBlock DockPanel.Dock="Left" 
                           Text="Имя пользователя"
                           Padding="10, 0, 0, 0"
                           Width="200"/>
                
                <TextBox DockPanel.Dock="Right" 
                         x:Name="NameUserTextBox"
                         Margin="0, 0, 5, 0"/>
            </DockPanel>

            <Border Height="25"/>

            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Пароль"
                           Padding="10, 0, 0, 0"
                           Width="200"/>
                
                <TextBox DockPanel.Dock="Right"
                         x:Name="PasswordTextBox"
                         Margin="0, 0, 5, 0"/>
            </DockPanel>

            <Border Height="25"/>

            <WrapPanel HorizontalAlignment="Center" Margin="5">
                <Button Content="Вход"
                        Padding="30, 0, 30, 0"
                        Click="EnterButton_Click"/>

                <Border Width="200"/>

                <Button Content="Отмена"
                        Padding="30, 0, 30, 0"
                        Click="CancelButton_Click"/>
            </WrapPanel>

            <WrapPanel HorizontalAlignment="Left" Margin="5">
                <TextBlock x:Name="LangTextBlock"
                           Text="Язык ввода"
                           Width="250"/>

                <TextBlock x:Name="KeyTextBlock"
                           Text="Клавиша"
                           HorizontalAlignment="Right"
                           Width="300"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
